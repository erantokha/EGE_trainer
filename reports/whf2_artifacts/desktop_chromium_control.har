"6a0c7a32-6c11\""},{"name":"expires","value":"Mon, 25 May 2026 10:05:11 GMT"},{"name":"last-modified","value":"Tue, 19 May 2026 14:56:50 GMT"},{"name":"server","value":"GitHub.com"},{"name":"strict-transport-security","value":"max-age=31556952"},{"name":"vary","value":"Accept-Encoding"},{"name":"via","value":"1.1 varnish"},{"name":"x-cache","value":"HIT"},{"name":"x-cache-hits","value":"1"},{"name":"x-fastly-request-id","value":"1f79bbb5ef80500db40f04e1498581c84975a7fa"},{"name":"x-github-request-id","value":"2706:535B2:CC5D63:CFAA81:6A141C7E"},{"name":"x-proxy-cache","value":"MISS"},{"name":"x-served-by","value":"cache-sof1510056-SOF"},{"name":"x-timer","value":"S1779708597.948739,VS0,VE125"}],"content":{"size":27665,"mimeType":"text/html; charset=utf-8","compression":20605,"text":"<!doctype html>\n<html lang=\"ru\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta http-equiv=\"Content-Security-Policy\" content=\"default-src 'self'; base-uri 'none'; object-src 'none'; form-action 'self'; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://js.sentry-cdn.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https://knhozdhvjhcovyjbjfji.supabase.co https://api.ege-trainer.ru https://ege-supabase-proxy.erantokha.workers.dev https://*.ingest.sentry.io https://*.sentry.io https://cdn.jsdelivr.net; frame-src https://rutube.ru;\">\n  <meta name=\"app-build\" content=\"2026-05-19-24\">\n  <!-- cache-check:start -->\n  <meta http-equiv=\"Cache-Control\" content=\"no-cache, must-revalidate\">\n  <meta http-equiv=\"Pragma\" content=\"no-cache\">\n  <script>\n  (function () {\n    try {\n      var meta = document.querySelector('meta[name=\"app-build\"]');\n      if (!meta) return;\n      var localBuild = (meta.content || '').trim();\n      if (!localBuild || localBuild === 'dev') return;\n      var SS_KEY = '__cacheCheckAttempts';\n      var attempts = 0;\n      try { attempts = parseInt(sessionStorage.getItem(SS_KEY) || '0', 10) || 0; } catch (e) {}\n      if (attempts >= 2) return;\n      fetch('/version.json?_=' + Date.now(), { cache: 'no-store' }).then(function (r) {\n        return r && r.ok ? r.json() : null;\n      }).then(function (j) {\n        if (!j || typeof j.build !== 'string') return;\n        if (j.build === localBuild) {\n          try { sessionStorage.removeItem(SS_KEY); } catch (e) {}\n          return;\n        }\n        try { sessionStorage.setItem(SS_KEY, String(attempts + 1)); } catch (e) {}\n        var doReload = function () { try { location.reload(); } catch (e) {} };\n        if (window.caches && caches.keys) {\n          caches.keys().then(function (keys) {\n            return Promise.all(keys.map(function (k) { return caches.delete(k); }));\n          }).then(doReload, doReload);\n        } else {\n          doReload();\n        }\n      }).catch(function () {});\n    } catch (e) {}\n  })();\n  </script>\n  <!-- cache-check:end -->\n  <title>EGE-trainer — подготовка к ЕГЭ по математике</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <meta name=\"description\" content=\"Тренажёр по задачам из банка ФИПИ. Статистика до каждого прототипа, домашнее задание в два клика, только официальные задания ЕГЭ.\">\n  <script src=\"./app/diag_bootstrap.js?v=2026-05-19-24\"></script>\n\n  <script id=\"sentry-loader\"\n    src=\"https://js.sentry-cdn.com/931c8cc8254b6dcb3de991c6c9844397.min.js\"\n    crossorigin=\"anonymous\"></script>\n  <script>\n  (function () {\n    if (window.__SENTRY_INITED__) return;\n    window.__SENTRY_INITED__ = true;\n    function getRelease() {\n      var m = document.querySelector('meta[name=\"app-build\"]');\n      return (m && m.getAttribute('content')) ? m.getAttribute('content') : 'unknown';\n    }\n    function getEnv() {\n      return (location.hostname === 'ege-trainer.ru') ? 'production' : 'staging';\n    }\n    function sanitizeEvent(event) {\n      try {\n        if (event && event.request && event.request.url)\n          event.request.url = event.request.url.split('#')[0].split('?')[0];\n        if (event && event.request && event.request.headers) {\n          delete event.request.headers.Authorization;\n          delete event.request.headers.authorization;\n          delete event.request.headers.Cookie;\n          delete event.request.headers.cookie;\n        }\n      } catch (e) {}\n      return event;\n    }\n    function doInit() {\n      if (!window.Sentry || !window.Sentry.init) return;\n      var opts = {\n        release: getRelease(),\n        environment: getEnv(),\n        initialScope: { tags: { page: location.pathname } },\n        beforeSend: sanitizeEvent\n      };\n      try {\n        if (window.Sentry.onLoad) { window.Sentry.onLoad(function () { window.Sentry.init(opts); }); return; }\n      } catch (e) {}\n      window.Sentry.init(opts);\n    }\n    doInit();\n  })();\n  </script>\n\n  <link rel=\"stylesheet\" href=\"./landing.css?v=2026-05-19-24\">\n  <noscript><style>body { visibility: visible !important; }</style></noscript>\n</head>\n<body class=\"gate-pending\">\n\n<!-- полоса прокрутки — заполняется по мере скролла страницы -->\n<div id=\"l-progress\" aria-hidden=\"true\"></div>\n\n<!-- ── Оверлей роутера: показывается залогиненным пользователям\n        пока home_router.js определяет роль и делает редирект ── -->\n<div id=\"rootRouterOverlay\" aria-hidden=\"true\">\n  <div id=\"rootRouterCard\">\n    <div id=\"rootRouterMsg\">Определяем роль…</div>\n    <div id=\"rootRouterBtns\">\n      <button id=\"rootRouterRetry\" type=\"button\" style=\"display:none\">Повторить</button>\n      <button id=\"rootRouterCopy\"  type=\"button\" style=\"display:none\">Скопировать детали</button>\n    </div>\n    <pre id=\"rootRouterDiag\" style=\"display:none\"></pre>\n  </div>\n</div>\n\n<!-- ══════════════════════════════════════════════════════════\n     NAV\n     ══════════════════════════════════════════════════════════ -->\n<nav class=\"l-nav\">\n  <div class=\"l-nav__inner\">\n    <span class=\"l-nav__logo\">EGE<span>-trainer</span></span>\n    <div class=\"l-nav__roles\">\n      <span class=\"l-nav__role l-nav__role--active\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" aria-hidden=\"true\">\n          <circle cx=\"7\" cy=\"4.5\" r=\"2.5\" fill=\"currentColor\"/>\n          <path d=\"M2 13c0-2.76 2.24-5 5-5s5 2.24 5 5\" stroke=\"currentColor\" stroke-width=\"1.4\" fill=\"none\" stroke-linecap=\"round\"/>\n          <rect x=\"5\" y=\"7.5\" width=\"4\" height=\"3\" rx=\"0.5\" fill=\"currentColor\" opacity=\"0.55\"/>\n        </svg>\n        Учитель\n      </span>\n      <a href=\"/student.html\" class=\"l-nav__role\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" aria-hidden=\"true\">\n          <circle cx=\"7\" cy=\"4.5\" r=\"2.5\" fill=\"currentColor\"/>\n          <path d=\"M2 13c0-2.76 2.24-5 5-5s5 2.24 5 5\" stroke=\"currentColor\" stroke-width=\"1.4\" fill=\"none\" stroke-linecap=\"round\"/>\n        </svg>\n        Ученик\n      </a>\n    </div>\n    <div class=\"l-nav__actions\">\n      <a href=\"/tasks/auth.html\" class=\"btn btn-primary\">Войти</a>\n    </div>\n  </div>\n</nav>\n\n\n\n<!-- ══════════════════════════════════════════════════════════\n     HERO\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-hero\">\n  <div class=\"container\">\n    <div class=\"l-hero__eyebrow\">Статистика по каждому прототипу ЕГЭ</div>\n    <h1 class=\"l-hero__h1\">\n      <span class=\"accent\">Ваш ученик хочет 70+ баллов?</span><br>\n      Узнайте, где именно он теряет баллы.\n    </h1>\n    <p class=\"l-hero__sub\">\n      Платформа для учителей, которые хотят работать точнее — а не больше.\n    </p>\n    <div class=\"l-hero__cta\">\n      <a href=\"/tasks/auth.html\" class=\"btn btn-primary btn-large\">Попробовать прямо сейчас →</a>\n      <a href=\"#demo\" class=\"btn btn-hero-ghost btn-large\">Как это работает</a>\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     BEFORE / AFTER\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-compare\">\n  <div class=\"container\">\n    <h2 class=\"l-section__title l-compare__title\">Как меняется работа учителя</h2>\n    <p class=\"l-section__sub\">До и после EGE-trainer</p>\n    <div class=\"l-compare__cards\">\n\n      <div class=\"l-compare__pair\">\n        <div class=\"l-cbox l-cbox--x\">\n          <span class=\"l-cbox__mark\">✗</span>\n          <p>«Саша плохо знает геометрию» — и на этом всё</p>\n        </div>\n        <span class=\"l-compare__arrow\">→</span>\n        <div class=\"l-cbox l-cbox--ok\">\n          <span class=\"l-cbox__mark\">✓</span>\n          <p>Прот. 1.3.2, точность 33%, не решал 23 дня — конкретика</p>\n        </div>\n      </div>\n\n      <div class=\"l-compare__pair\">\n        <div class=\"l-cbox l-cbox--x\">\n          <span class=\"l-cbox__mark\">✗</span>\n          <p>Задачи из рабочей тетради — одинаковые для всех</p>\n        </div>\n        <span class=\"l-compare__arrow\">→</span>\n        <div class=\"l-cbox l-cbox--ok\">\n          <span class=\"l-cbox__mark\">✓</span>\n          <p>Персональное ДЗ по слабым местам каждому ученику</p>\n        </div>\n      </div>\n\n      <div class=\"l-compare__pair\">\n        <div class=\"l-cbox l-cbox--x\">\n          <span class=\"l-cbox__mark\">✗</span>\n          <p>Проверка тетрадей и ручное занесение результатов</p>\n        </div>\n        <span class=\"l-compare__arrow\">→</span>\n        <div class=\"l-cbox l-cbox--ok\">\n          <span class=\"l-cbox__mark\">✓</span>\n          <p>Результаты сами приходят в статистику</p>\n        </div>\n      </div>\n\n      <div class=\"l-compare__pair\">\n        <div class=\"l-cbox l-cbox--x\">\n          <span class=\"l-cbox__mark\">✗</span>\n          <p>30–40 минут на подготовку к уроку</p>\n        </div>\n        <span class=\"l-compare__arrow\">→</span>\n        <div class=\"l-cbox l-cbox--ok\">\n          <span class=\"l-cbox__mark\">✓</span>\n          <p>5 минут: открыли профиль, увидели слабые места, выдали ДЗ</p>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     FEATURES\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-features\">\n  <div class=\"container\">\n    <h2 class=\"l-section__title l-compare__title\">Почему EGE-trainer</h2>\n    <p class=\"l-section__sub l-features__sub\">Три вещи, которых нет ни на одной другой платформе</p>\n    <div class=\"l-features__grid\">\n\n      <div class=\"l-feature-card\">\n        <div class=\"l-feature-card__icon\">📊</div>\n        <div class=\"l-feature-card__title\">Карта пробелов всего класса</div>\n        <p class=\"l-feature-card__text\">\n          Видите не только одного ученика, но и весь класс сразу: какие прототипы\n          проседают у большинства, где средняя точность ниже 50%,\n          и кому нужно индивидуальное задание.\n        </p>\n      </div>\n\n      <div class=\"l-feature-card\">\n        <div class=\"l-feature-card__icon\">⚡</div>\n        <div class=\"l-feature-card__title\">Домашнее задание в два клика</div>\n        <p class=\"l-feature-card__text\">\n          Выбрали задачи по слабым местам — нажали «Создать ДЗ» — отправили\n          персональную ссылку. Результаты автоматически появляются\n          в статистике ученика.\n        </p>\n      </div>\n\n      <div class=\"l-feature-card\">\n        <div class=\"l-feature-card__icon\">🎯</div>\n        <div class=\"l-feature-card__title\">Только ФИПИ</div>\n        <p class=\"l-feature-card__text\">\n          Никакого лишнего контента. Каждая задача — из официального открытого\n          банка Федерального института педагогических измерений.\n          Именно то, что выйдет на экзамене.\n        </p>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     STATS\n     Замени цифры на реальные перед запуском в прод\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-stats\">\n  <div class=\"container\">\n    <div class=\"l-stats__grid\">\n      <div>\n        <div class=\"l-stat__number\">4 000+</div>\n        <div class=\"l-stat__label\">задач из банка ФИПИ</div>\n      </div>\n      <div>\n        <div class=\"l-stat__number\">5 мин</div>\n        <div class=\"l-stat__label\">на подготовку к занятию</div>\n      </div>\n      <div>\n        <div class=\"l-stat__number\">100%</div>\n        <div class=\"l-stat__label\">официальные задания ЕГЭ</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     DEMO MOCK\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-demo\" id=\"demo\">\n  <div class=\"container\">\n    <h2 class=\"l-section__title l-compare__title\">Вот что видит учитель</h2>\n    <p class=\"l-section__sub l-features__sub\">Профиль ученика — статистика каждого прототипа</p>\n    <div class=\"l-demo__wrap\">\n\n      <div class=\"mock\">\n        <!-- фейковый тайтлбар браузера -->\n        <div class=\"mock__titlebar\">\n          <div class=\"mock__dot mock__dot--r\"></div>\n          <div class=\"mock__dot mock__dot--y\"></div>\n          <div class=\"mock__dot mock__dot--g\"></div>\n        </div>\n\n        <div class=\"mock__body\">\n          <!-- шапка профиля -->\n          <div class=\"mock__head\">\n            <span class=\"mock__name\">Саша К. · цель: 80+ баллов</span>\n            <div class=\"mock__periods\">\n              <span class=\"mock__period mock__period--active\">7д</span>\n              <span class=\"mock__period\">14д</span>\n              <span class=\"mock__period\">30д</span>\n              <span class=\"mock__period\">90д</span>\n            </div>\n          </div>\n\n          <!-- тема 1.1 — хорошо -->\n          <div class=\"mock__row\">\n            <div class=\"mock__row-head\">\n              <span class=\"mock__row-label\">1.1 Площади фигур</span>\n              <div class=\"mock__row-meta\">\n                <span class=\"mock__badge mock__badge--ok\">78%</span>\n                <span>✓ 2 дня назад</span>\n              </div>\n            </div>\n            <div class=\"mock__bar-wrap\">\n              <div class=\"mock__bar-fill\" style=\"width:78%; background:#16a34a\"></div>\n            </div>\n          </div>\n\n          <!-- тема 1.3 — слабая -->\n          <div class=\"mock__row\">\n            <div class=\"mock__row-head\">\n              <span class=\"mock__row-label\">3.2 Прогрессии</span>\n              <div class=\"mock__row-meta\">\n                <span class=\"mock__badge mock__badge--warn\">42%</span>\n                <span>⚠ 23 дня назад</span>\n              </div>\n            </div>\n            <div class=\"mock__bar-wrap\">\n              <div class=\"mock__bar-fill\" style=\"width:42%; background:#d97706\"></div>\n            </div>\n          </div>\n\n          <!-- тема 7.1 — критично -->\n          <div class=\"mock__row\">\n            <div class=\"mock__row-head\">\n              <span class=\"mock__row-label\">7.1 Производная</span>\n              <div class=\"mock__row-meta\">\n                <span class=\"mock__badge mock__badge--danger\">20%</span>\n                <span>✗ не решал</span>\n              </div>\n            </div>\n            <div class=\"mock__bar-wrap\">\n              <div class=\"mock__bar-fill\" style=\"width:20%; background:#dc2626\"></div>\n            </div>\n          </div>\n\n          <!-- прототипы -->\n          <div class=\"mock__protos\">\n            <div class=\"mock__proto\">\n              <div class=\"mock__proto-id\">прот. 1.3.2</div>\n              <div class=\"mock__proto-acc mock__proto-acc--warn\">точность 33% · 12 дн.</div>\n            </div>\n            <div class=\"mock__proto\">\n              <div class=\"mock__proto-id\">прот. 1.7.1</div>\n              <div class=\"mock__proto-acc mock__proto-acc--new\">не решал</div>\n            </div>\n            <div class=\"mock__proto\">\n              <div class=\"mock__proto-id\">прот. 2.4.3</div>\n              <div class=\"mock__proto-acc mock__proto-acc--warn\">точность 25% · 31 дн.</div>\n            </div>\n            <div class=\"mock__proto\">\n              <div class=\"mock__proto-id\">прот. 3.1.2</div>\n              <div class=\"mock__proto-acc mock__proto-acc--new\">не решал</div>\n            </div>\n            <div class=\"mock__proto\">\n              <div class=\"mock__proto-id\">прот. 5.2.1</div>\n              <div class=\"mock__proto-acc mock__proto-acc--warn\">точность 40% · 18 дн.</div>\n            </div>\n            <div class=\"mock__proto\">\n              <div class=\"mock__proto-id\">прот. 7.3.4</div>\n              <div class=\"mock__proto-acc mock__proto-acc--new\">не решал</div>\n            </div>\n          </div>\n\n          <!-- CTA внутри мока -->\n          <div class=\"mock__cta-row\">\n            <a href=\"/tasks/auth.html\" class=\"mock__cta-btn\">Создать ДЗ из выбранных (3) →</a>\n          </div>\n        </div>\n      </div>\n\n      <p class=\"l-demo__caption\">\n        Реальный интерфейс — по каждому прототипу видна точность и давность последней попытки\n      </p>\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     TESTIMONIALS\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-testimonials\">\n  <div class=\"container\">\n    <h2 class=\"l-section__title l-compare__title\">Что говорят преподаватели</h2>\n    <p class=\"l-section__sub l-features__sub\"> </p>\n    <div class=\"l-testimonials__grid\">\n\n      <div class=\"l-tcard\">\n        <div class=\"l-tcard__avatar\">М</div>\n        <div class=\"l-tcard__name\">Марина</div>\n        <div class=\"l-tcard__role\">Репетитор по математике, Москва</div>\n        <div class=\"l-tcard__quote\">\n          Раньше тратила по полчаса на подготовку к каждому ученику. Теперь открываю профиль,\n          смотрю на красные прототипы и сразу понимаю, что задавать. Это реально экономит время.\n        </div>\n      </div>\n\n      <div class=\"l-tcard\">\n        <div class=\"l-tcard__avatar\">А</div>\n        <div class=\"l-tcard__name\">Алексей</div>\n        <div class=\"l-tcard__role\">Учитель математики, школа №47</div>\n        <div class=\"l-tcard__quote\">\n          У меня 67 учеников. Раньше я просто не мог отслеживать каждого индивидуально —\n          не хватало времени. Теперь вижу в одном месте, кто где застрял, и даю задания точечно.\n        </div>\n      </div>\n\n      <div class=\"l-tcard\">\n        <div class=\"l-tcard__avatar\">О</div>\n        <div class=\"l-tcard__name\">Ольга</div>\n        <div class=\"l-tcard__role\">Онлайн-репетитор</div>\n        <div class=\"l-tcard__quote\">\n          Ценю, что здесь только задачи из реального банка ФИПИ, без авторских «похожих».\n          Ученики решают именно то, что может попасться на экзамене, — и это чувствуется в результатах.\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     FAQ\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-faq\">\n  <div class=\"container\">\n    <h2 class=\"l-section__title l-compare__title\">Вопросы и ответы</h2>\n    <p class=\"l-section__sub\"> </p>\n    <div class=\"l-faq__list\">\n\n      <details class=\"l-faq__item\">\n        <summary>Зачем ученику регистрироваться?</summary>\n        <div class=\"l-faq__answer\">\n          Без регистрации статистика не накапливается — значит, учитель не видит прогресс\n          и не может точечно подобрать задачи. Регистрация занимает 30 секунд\n          и открывает весь функционал: тренировки, ДЗ, аналитику по темам.\n        </div>\n      </details>\n\n      <details class=\"l-faq__item\">\n        <summary>Задачи актуальны для ЕГЭ 2026?</summary>\n        <div class=\"l-faq__answer\">\n          Да. Используется только официальный открытый банк заданий Федерального института\n          педагогических измерений (ФИПИ). Никакого авторского контента — только то,\n          что выйдет на экзамене.\n        </div>\n      </details>\n\n      <details class=\"l-faq__item\">\n        <summary>Что такое «прототип»?</summary>\n        <div class=\"l-faq__answer\">\n          Каждое задание ЕГЭ из банка ФИПИ имеет «корень» — уникальный прототип.\n          Формулировки у разных задач могут отличаться, но суть одна. EGE-trainer\n          отслеживает, какие прототипы ученик освоил, а какие нет — это точнее,\n          чем просто «тема».\n        </div>\n      </details>\n\n      <details class=\"l-faq__item\">\n        <summary>Как добавить ученика?</summary>\n        <div class=\"l-faq__answer\">\n          После регистрации вы получаете кабинет учителя. Ученик регистрируется\n          самостоятельно и вас находит, или вы приглашаете его по ссылке.\n          Всё готово за несколько минут.\n        </div>\n      </details>\n\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     FINAL CTA\n     ══════════════════════════════════════════════════════════ -->\n<section class=\"l-cta\">\n  <div class=\"container\">\n    <h2 class=\"l-cta__title\">Начните с первого ученика</h2>\n    <p class=\"l-cta__sub\">Регистрация за 30 секунд.</p>\n    <div class=\"l-cta__actions\">\n      <a href=\"/tasks/auth.html\" class=\"btn btn-white btn-large\">Зарегистрироваться →</a>\n      <a href=\"/tasks/auth.html\" class=\"btn btn-outline-white btn-large\">Войти через Google</a>\n    </div>\n  </div>\n</section>\n\n<!-- ══════════════════════════════════════════════════════════\n     FOOTER\n     ══════════════════════════════════════════════════════════ -->\n<footer class=\"l-footer\">\n  <span>© 2026 EGE-trainer</span>\n  <span>·</span>\n  <a href=\"/privacy.html\">Политика конфиденциальности</a>\n  <span>·</span>\n  <a href=\"/terms.html\">Условия использования</a>\n  <span>·</span>\n  <a href=\"mailto:<email_redacted>\"><email_redacted></a>\n</footer>\n\n<!-- home_router определяет роль залогиненного пользователя\n     и редиректит на home_student.html / home_teacher.html.\n     Для незалогиненных — снимает gate-pending и показывает лендинг. -->\n<script type=\"module\" src=\"./tasks/home_router.js?v=2026-05-19-24\"></script>\n\n<script>\n// Лендинг — статический HTML, не требует API для отображения.\n// Помечаем страницу готовой сразу после загрузки DOM, чтобы watchdog\n// в diag_bootstrap.js не срабатывал из-за недоступных опциональных\n// ресурсов (Sentry CDN может быть заблокирован в РФ).\ndocument.addEventListener('DOMContentLoaded', function () {\n  if (window.__EGE_DIAG__ && window.__EGE_DIAG__.markReady) {\n    window.__EGE_DIAG__.markReady();\n  }\n});\n\n// полоса прокрутки\n(function () {\n  var bar = document.getElementById('l-progress');\n  if (!bar) return;\n  function update() {\n    var scrollTop = document.documentElement.scrollTop || document.body.scrollTop;\n    var total = document.documentElement.scrollHeight - document.documentElement.clientHeight;\n    bar.style.width = (total > 0 ? (scrollTop / total * 100) : 0) + '%';\n  }\n  window.addEventListener('scroll', update, { passive: true });\n  update();\n})();\n</script>\n\n</body>\n</html>\n"},"headersSize":0,"bodySize":7060,"redirectURL":"","_transferSize":7060},"cache":{},"timings":{"dns":-1,"connect":-1,"ssl":-1,"send":0,"wait":158.498,"receive":1.798},"serverIPAddress":"185.199.110.153","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.3","subjectName":"ege-trainer.ru","issuer":"R12","validFrom":1778277113,"validTo