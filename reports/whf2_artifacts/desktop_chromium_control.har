sanitizeEvent(event) {\n    try {\n      if (event && event.request && event.request.url) {\n        event.request.url = event.request.url.split('#')[0].split('?')[0];\n      }\n      if (event && event.request && event.request.headers) {\n        delete event.request.headers.Authorization;\n        delete event.request.headers.authorization;\n        delete event.request.headers.Cookie;\n        delete event.request.headers.cookie;\n      }\n    } catch (e) {}\n    return event;\n  }\n\n  function doInit() {\n    if (!window.Sentry || !window.Sentry.init) return;\n\n    var opts = {\n      release: getRelease(),\n      environment: getEnv(),\n      initialScope: {\n        tags: { page: location.pathname }\n      },\n      beforeSend: sanitizeEvent\n    };\n\n    try {\n      if (window.Sentry.onLoad) {\n        window.Sentry.onLoad(function () {\n          window.Sentry.init(opts);\n        });\n        return;\n      }\n    } catch (e) {}\n\n    window.Sentry.init(opts);\n  }\n\n  doInit();\n})();\n</script>\n\n  \n  \n  <link rel=\"stylesheet\" href=\"./trainer.css?v=2026-05-19-24\">\n  <script src=\"./theme.js?v=2026-05-19-24\" defer></script>\n  <style>\n    input[type=\"email\"],\n    input[type=\"password\"],\n    input[type=\"text\"],\n    select{\n      background:var(--muted);\n      color:var(--text);\n      border:1px solid var(--border);\n      border-radius:10px;\n      padding:8px 10px;\n      outline:none;\n      width:100%;\n      box-sizing:border-box;\n    }\n\n    /* Заголовок в шапке как на главной */\n    .page-head h1{margin:0}\n\n    .auth-box{max-width:920px;margin:12px auto 0}\n    .auth-grid{display:flex;gap:24px;justify-content:space-between;align-items:flex-start;flex-wrap:wrap}\n    .auth-col{flex:1 1 320px;min-width:280px}\n\n    .provider-btn{\n      width:100%;\n      max-width:360px;\n      display:flex;\n      align-items:center;\n      gap:12px;\n      justify-content:center;\n      padding:14px 16px;\n      border-radius:16px;\n      border:1px solid var(--border);\n      background:var(--panel);\n      color:var(--text);\n      cursor:pointer;\n    }\n    .provider-logo{width:28px;height:28px;object-fit:contain}\n\n    .mail-head{display:flex;align-items:center;gap:12px;margin:2px 0 12px}\n    .mail-logo{width:46px;height:46px;object-fit:contain}\n    .mail-caption{font-size:16px}\n\n    .mail-form-wrap{max-width:260px} /* в 2 раза уже прежних 520px */\n    .form-row{margin:10px 0}\n    .form-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-top:12px}\n\n    .auth-links{display:flex;gap:14px;flex-wrap:wrap;margin-top:12px}\n    .auth-links a{color:var(--text);text-decoration:underline}\n    .auth-links a:hover{opacity:.85}\n    .auth-links a.active{text-decoration:none;opacity:.8;cursor:default}\n\n    .status{margin-top:10px;opacity:.85}\n    .status.error{opacity:1;color:#b00}\n    .small{font-size:12px;opacity:.8}\n\n    .radio-row{display:flex;gap:14px;flex-wrap:wrap;align-items:center}\n    .radio-row label{display:flex;gap:6px;align-items:center}\n\n    .pw-wrap{position:relative}\n    .pw-wrap input{padding-right:38px}\n    .pw-toggle{\n      position:absolute;\n      right:8px;\n      top:50%;\n      transform:translateY(-50%);\n      border:0;\n      background:transparent;\n      cursor:pointer;\n      opacity:.75;\n      padding:2px 4px;\n      line-height:1;\n    }\n    .pw-toggle:hover{opacity:1}\n\n    /* На auth странице скрываем кнопку \"Войти\" из header.js (на всякий случай) */\n    #loginGoogleBtn{display:none !important}\n  </style>\n</head>\n<body>\n  <main class=\"container\">\n    <section id=\"auth\">\n      <div class=\"panel\">\n        <header id=\"appHeader\" class=\"page-head\">\n          <h1>Авторизация</h1>\n          <div class=\"theme-toggle\" data-header-extra=\"1\">\n            <input type=\"checkbox\" id=\"themeToggle\" class=\"theme-toggle-input\" aria-label=\"Переключить тему\">\n            <label for=\"themeToggle\" class=\"theme-toggle-label\">\n              <span class=\"theme-toggle-icon theme-toggle-icon-light\">☀</span>\n              <span class=\"theme-toggle-icon theme-toggle-icon-dark\">🌙</span>\n            </label>\n          </div>\n        </header>\n        <script type=\"module\">\n          const BUILD = document.querySelector('meta[name=\"app-build\"]')?.content?.trim();\n          const withV = (p) => BUILD ? `${p}${p.includes('?') ? '&' : '?'}v=${encodeURIComponent(BUILD)}` : p;\n          import(withV('../app/ui/header.js')).then((m) => m.initHeader({ isHome: false, hideLogin: true }));\n        </script>\n\n        <div class=\"auth-box\">\n          <div class=\"auth-grid\">\n            <div class=\"auth-col auth-google\">\n              <button id=\"googleBtn\" type=\"button\" class=\"provider-btn\">\n                <img class=\"provider-logo\" src=\"./img/google.png\" alt=\"Google\">\n                <span>Войти через Google</span>\n              </button>\n            </div>\n\n            <div class=\"auth-col auth-mail\">\n              <div class=\"mail-head\">\n                <img class=\"mail-logo\" src=\"./img/post.png\" alt=\"Почта\">\n                <div class=\"mail-caption\">Вход через логин и пароль</div>\n              </div>\n\n              <div class=\"mail-form-wrap\">\n                <section id=\"panelLogin\">\n                  <form id=\"loginForm\">\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Email</div>\n                      <input id=\"loginEmail\" type=\"email\" autocomplete=\"email\" required>\n                    </div>\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Пароль</div>\n                      <div class=\"pw-wrap\">\n                        <input id=\"loginPass\" type=\"password\" autocomplete=\"current-password\" required>\n                        <button type=\"button\" class=\"pw-toggle\" data-toggle-for=\"loginPass\" aria-label=\"Показать пароль\" title=\"Показать пароль\">👁</button>\n                      </div>\n                    </div>\n                    <div class=\"form-actions\">\n                      <button id=\"loginSubmit\" type=\"submit\">Войти</button>\n                    </div>\n                    <div id=\"loginStatus\" class=\"status\"></div>\n                  </form>\n                </section>\n\n                <section id=\"panelSignup\" class=\"hidden\">\n                  <form id=\"signupForm\">\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Кто вы?</div>\n                      <div class=\"radio-row\" role=\"radiogroup\" aria-label=\"Роль\">\n                        <label><input type=\"radio\" name=\"signupRole\" value=\"student\" checked> Ученик</label>\n                        <label><input type=\"radio\" name=\"signupRole\" value=\"teacher\"> Учитель</label>\n                      </div>\n                    </div>\n\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Фамилия</div>\n                      <input id=\"signupLastName\" type=\"text\" autocomplete=\"family-name\" required>\n                    </div>\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Имя</div>\n                      <input id=\"signupFirstName\" type=\"text\" autocomplete=\"given-name\" required>\n                    </div>\n\n                    <div id=\"studentFields\">\n                      <div class=\"form-row\">\n                        <div class=\"small\" style=\"margin-bottom:6px\">Класс</div>\n                        <select id=\"signupGrade\" required>\n                          <option value=\"\" selected disabled>Выберите класс</option>\n                          <option value=\"5\">5</option>\n                          <option value=\"6\">6</option>\n                          <option value=\"7\">7</option>\n                          <option value=\"8\">8</option>\n                          <option value=\"9\">9</option>\n                          <option value=\"10\">10</option>\n                          <option value=\"11\">11</option>\n                        </select>\n                      </div>\n                    </div>\n\n                    <div id=\"teacherFields\" class=\"hidden\">\n                      <div class=\"form-row\">\n                        <div class=\"small\" style=\"margin-bottom:6px\">Вы</div>\n                        <select id=\"signupTeacherType\">\n                          <option value=\"\" selected disabled>Выберите вариант</option>\n                          <option value=\"school\">Школьный учитель</option>\n                          <option value=\"tutor\">Репетитор</option>\n                        </select>\n                      </div>\n                    </div>\n\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Email</div>\n                      <input id=\"signupEmail\" type=\"email\" autocomplete=\"email\" required>\n                    </div>\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Пароль</div>\n                      <div class=\"pw-wrap\">\n                        <input id=\"signupPass\" type=\"password\" autocomplete=\"new-password\" required>\n                        <button type=\"button\" class=\"pw-toggle\" data-toggle-for=\"signupPass\" aria-label=\"Показать пароль\" title=\"Показать пароль\">👁</button>\n                      </div>\n                    </div>\n\n                    <div class=\"form-actions\">\n                      <button id=\"signupSubmit\" type=\"submit\">Зарегистрироваться</button>\n                      <button id=\"resendBtn\" type=\"button\" class=\"hidden\">Отправить письмо ещё раз</button>\n                    </div>\n                    <div id=\"signupStatus\" class=\"status\"></div>\n                    <div class=\"small\" style=\"margin-top:8px\">После регистрации нужно подтвердить почту по ссылке из письма.</div>\n                  </form>\n                </section>\n\n                <section id=\"panelReset\" class=\"hidden\">\n                  <form id=\"resetForm\">\n                    <div class=\"form-row\">\n                      <div class=\"small\" style=\"margin-bottom:6px\">Email</div>\n                      <input id=\"resetEmail\" type=\"email\" autocomplete=\"email\" required>\n                    </div>\n                    <div class=\"form-actions\">\n                      <button id=\"resetSubmit\" type=\"submit\">Отправить письмо</button>\n                    </div>\n                    <div id=\"resetStatus\" class=\"status\"></div>\n                  </form>\n                </section>\n              </div>\n\n              <div class=\"auth-links\" role=\"navigation\" aria-label=\"Действия\">\n                <a id=\"tabLogin\" href=\"#\" class=\"active\" aria-selected=\"true\">Войти</a>\n                <a id=\"tabSignup\" href=\"#\" aria-selected=\"false\">Регистрация</a>\n                <a id=\"tabReset\" href=\"#\" aria-selected=\"false\">Сменить пароль</a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <script type=\"module\" src=\"./auth.js?v=2026-05-19-24\"></script>\n</body>\n</html>\n"},"headersSize":0,"bodySize":4463,"redirectURL":"","_transferSize":4463},"cache":{},"timings":{"dns":1.768,"connect":147.483,"ssl":87.337,"send":0,"wait":50.733,"receive":2.153},"serverIPAddress":"185.199.110.153","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.3","subjectName":"ege-trainer.ru","issuer":"R12","validFrom":1778277113,"validTo":1786053112}},{"pageref":"page@0e8694ce6066cb070a0331dc86d8c