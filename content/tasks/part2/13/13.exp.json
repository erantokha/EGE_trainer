          "max_primary": 2,
          "stem": "а) Решите уравнение \\(8 \\cdot 16^{\\sin x} - 6 \\cdot 4^{\\sin x} + 1 = 0\\).<br>б) Найдите все корни уравнения, принадлежащие отрезку \\(\\left[- \\frac{11 \\pi}{2};\\ - 4 \\pi\\right]\\).",
          "answer_spec": {
            "type": "manual"
          },
          "answer": {
            "general": [
              "x = - \\frac{\\pi}{2} + 2\\pi n,\\ n \\in \\mathbb{Z}",
              "x = - \\frac{\\pi}{6} + 2\\pi n,\\ n \\in \\mathbb{Z}",
              "x = \\frac{7 \\pi}{6} + 2\\pi n,\\ n \\in \\mathbb{Z}"
            ],
            "roots": [
              "- \\frac{29 \\pi}{6}",
              "- \\frac{9 \\pi}{2}",
              "- \\frac{25 \\pi}{6}"
            ]
          },
          "solution": {
            "steps": [
              "8 \\cdot 16^{\\sin x} - 6 \\cdot 4^{\\sin x} + 1 = 0",
              "u = 4^{\\sin x},\\quad u > 0",
              "16^{\\sin x} = \\bigl(4^{\\sin x}\\bigr)^2 = u^2",
              "8 u^2 - 6 u + 1 = 0",
              "8\\bigl(u - \\frac{1}{4}\\bigr)\\bigl(u - \\frac{1}{2}\\bigr) = 0",
              "u = \\frac{1}{4},\\quad u = \\frac{1}{2}",
              "4^{\\sin x} = \\frac{1}{4},\\quad 4^{\\sin x} = \\frac{1}{2}",
              "4^{\\sin x} = 4^{-1},\\quad 4^{\\sin x} = 4^{-\\frac{1}{2}}",
              "\\sin x = -1,\\quad \\sin x = -\\frac{1}{2}"
            ],
            "gen_groups": [
              {
                "head": "\\sin x = -1",
                "series": [
                  "x = - \\frac{\\pi}{2} + 2\\pi n"
                ]
              },
              {
                "head": "\\sin x = -\\frac{1}{2}",
                "series": [
                  "x = - \\frac{\\pi}{6} + 2\\pi n",
                  "x = \\frac{7 \\pi}{6} + 2\\pi n"
                ]
              }
            ],
            "below": [
              "x_{1} = - 5 \\pi + \\frac{\\pi}{6} = - \\frac{29 \\pi}{6}",
              "x_{2} = - \\frac{9 \\pi}{2}",
              "x_{3} = - 4 \\pi - \\frac{\\pi}{6} = - \\frac{25 \\pi}{6}"
            ],
            "figure": "content/tasks/part2/13/img/part2/Б13-067.svg"
          },
          "unic": true
