          "max_primary": 2,
          "stem": "а) Решите уравнение \\(2 \\cdot \\log_{2}^2\\bigl(2\\sin x\\bigr) - 5 \\cdot \\log_{2}\\bigl(2\\sin x\\bigr) + 2 = 0\\).<br>б) Найдите все корни уравнения, принадлежащие отрезку \\(\\left[- \\frac{9 \\pi}{2};\\ - 3 \\pi\\right]\\).",
          "answer_spec": {
            "type": "manual"
          },
          "answer": {
            "general": [
              "x = \\frac{\\pi}{4} + 2\\pi n,\\ n \\in \\mathbb{Z}",
              "x = \\frac{3 \\pi}{4} + 2\\pi n,\\ n \\in \\mathbb{Z}"
            ],
            "roots": [
              "- \\frac{15 \\pi}{4}",
              "- \\frac{13 \\pi}{4}"
            ]
          },
          "solution": {
            "steps": [
              "2 \\cdot \\log_{2}^2\\bigl(2\\sin x\\bigr) - 5 \\cdot \\log_{2}\\bigl(2\\sin x\\bigr) + 2 = 0",
              "\\text{ОДЗ: } 2\\sin x > 0",
              "w = \\log_{2}\\bigl(2\\sin x\\bigr)",
              "2 w^2 - 5 w + 2 = 0",
              "2\\bigl(w - \\frac{1}{2}\\bigr)\\bigl(w - 2\\bigr) = 0",
              "w = \\frac{1}{2},\\quad w = 2",
              "\\log_{2}\\bigl(2\\sin x\\bigr) = \\frac{1}{2},\\quad \\log_{2}\\bigl(2\\sin x\\bigr) = 2",
              "2\\sin x = 2^{\\frac{1}{2}},\\quad 2\\sin x = 2^2",
              "\\sin x = \\frac{\\sqrt{2}}{2},\\quad \\sin x = 2",
              "\\sin x = 2 \\text{ не подходит, так как } |\\sin x| \\le 1"
            ],
            "gen_groups": [
              {
                "head": "\\sin x = \\frac{\\sqrt{2}}{2}",
                "series": [
                  "x = \\frac{\\pi}{4} + 2\\pi n",
                  "x = \\frac{3 \\pi}{4} + 2\\pi n"
                ]
              }
            ],
            "below": [
              "x_{1} = - 4 \\pi + \\frac{\\pi}{4} = - \\frac{15 \\pi}{4}",
              "x_{2} = - \\frac{7 \\pi}{2} + \\frac{\\pi}{4} = - \\frac{13 \\pi}{4}"
            ],
            "figure": "content/tasks/part2/13/img/part2/Б13-070.svg"
          },
          "unic": true
