          "max_primary": 2,
          "stem": "а) Решите уравнение \\(3\\cos\\bigl(x - \\frac{\\pi}{6}\\bigr) - \\sqrt{3}\\,\\sin\\bigl(\\frac{\\pi}{2} - x\\bigr) = 0\\).<br>б) Найдите все корни уравнения, принадлежащие отрезку \\(\\left[- \\frac{11 \\pi}{2};\\ - 4 \\pi\\right]\\).",
          "answer_spec": {
            "type": "manual"
          },
          "answer": {
            "general": [
              "x = - \\frac{\\pi}{6} + \\pi n,\\ n \\in \\mathbb{Z}"
            ],
            "roots": [
              "- \\frac{31 \\pi}{6}",
              "- \\frac{25 \\pi}{6}"
            ]
          },
          "solution": {
            "steps": [
              "3\\cos\\bigl(x - \\frac{\\pi}{6}\\bigr) - \\sqrt{3}\\,\\sin\\bigl(\\frac{\\pi}{2} - x\\bigr) = 0",
              {
                "kind": "formula_hint",
                "formulas": [
                  {
                    "tex": "\\cos\\bigl(\\alpha - \\beta\\bigr) = \\cos\\alpha\\cos\\beta + \\sin\\alpha\\sin\\beta"
                  }
                ]
              },
              {
                "kind": "formula_hint",
                "formulas": [
                  {
                    "tex": "\\sin\\bigl(\\frac{\\pi}{2} - x\\bigr) = \\cos x"
                  }
                ]
              },
              "3 \\bigl(\\frac{\\sqrt{3}}{2} \\cos x + \\frac{1}{2} \\sin x\\bigr) - \\sqrt{3} \\cos x = 0",
              "\\frac{3 \\sqrt{3}}{2} \\cos x + \\frac{3}{2} \\sin x - \\sqrt{3} \\cos x = 0",
              "\\frac{3}{2} \\sin x + \\frac{\\sqrt{3}}{2} \\cos x = 0",
              "\\cos x \\ne 0",
              "\\frac{3}{2}\\cdot\\frac{\\sin x}{\\cos x} + \\frac{\\sqrt{3}}{2} = 0",
              {
                "kind": "formula_hint",
                "formulas": [
                  {
                    "tex": "\\operatorname{tg} x = \\frac{\\sin x}{\\cos x}"
                  }
                ]
              },
              "\\frac{3}{2}\\operatorname{tg} x + \\frac{\\sqrt{3}}{2} = 0",
              "\\operatorname{tg} x = - \\frac{\\sqrt{3}}{3}"
            ],
            "gen_groups": [
              {
                "head": "\\operatorname{tg} x = - \\frac{\\sqrt{3}}{3}",
                "series": [
                  "x = - \\frac{\\pi}{6} + \\pi n"
                ]
              }
            ],
            "below": [
              "x_{1} = - 5 \\pi - \\frac{\\pi}{6} = - \\frac{31 \\pi}{6}",
              "x_{2} = - 4 \\pi - \\frac{\\pi}{6} = - \\frac{25 \\pi}{6}"
            ],
            "figure": "content/tasks/part2/13/img/part2/Б13-001.svg"
          },
