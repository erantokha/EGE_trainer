              "x = \\frac{\\pi}{3} + 2\\pi n,\\ n \\in \\mathbb{Z}",
              "x = \\frac{5 \\pi}{3} + 2\\pi n,\\ n \\in \\mathbb{Z}",
              "x = \\frac{3 \\pi}{2} + 2\\pi n,\\ n \\in \\mathbb{Z}"
